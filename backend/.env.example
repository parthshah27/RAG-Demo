# RAG Hackathon .env - Copy to .env and fill keys
# Get free keys: OpenAI https://platform.openai.com | Groq https://console.groq.com | Ollama local

LLM_PROVIDER=openai  # openai, groq, ollama, anthropic
LLM_API_KEY=sk-...   # OpenAI/Groq/Anthropic key
LLM_MODEL=gpt-4o-mini  # openai: gpt-4o-mini | groq: llama3-groq-70b-8192 | ollama: llama3.2

EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

CONFIG_FILE=config.hackathon.json
DEMO_MODE=false

# Optional
CHROMA_PERSIST_DIR=./chroma_db
VERIFY_SSL=true
