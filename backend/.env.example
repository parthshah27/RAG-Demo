# ============================================
# HACKATHON MODE - CRITICAL SETTINGS
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here

# Domain Selection (from config/ folder)
# Examples: manufacturing, retail, healthcare, your_domain
CONFIG_FILE=config.your_domain.json

# ============================================
# DEMO MODE (For Testing Without API Calls)
# ============================================
# Set to True to test UI/UX instantly without API costs
# Responses come from demo_responses in your config file
DEMO_MODE=False

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Development
# ============================================
DEBUG=True
LOG_LEVEL=INFO

# ============================================
# DATABASE (ChromaDB is automatic - disk-based)
# ============================================
# ChromaDB automatically uses: backend/.chroma/
# No configuration needed - it just works!
# Clear with: rm -rf .chroma/

# ============================================
# HACKATHON QUICK TIPS
# ============================================
# 1. Switch domains fast:
#    python scripts/quickstart.py --switch your_domain
#
# 2. Generate test data:
#    python scripts/quickstart.py --switch your_domain --generate 1000
#
# 3. Configure behavior via:
#    config/config.your_domain.json
#
# 4. Test without API cost:
#    DEMO_MODE=True
